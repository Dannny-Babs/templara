{
  "name": "@templara/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev --port 3001",
    "preview": "serve ./build/client --config serve.json",
    "typecheck": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^8.1.0",
    "@templara/core": "workspace:*",
    "@templara/react-renderer": "workspace:*",
    "@templara/renderer": "workspace:*",
    "@templara/templates": "workspace:*",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.1",
    "isbot": "^5.1.44",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@react-router/dev": "^8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-router-devtools": "^6.2.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0",
    "vite": "^8.1.3"
  }
}
